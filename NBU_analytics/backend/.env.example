# Copy to .env for local dev. Do not commit .env.
# ----- Application -----
APP_ENV=dev
# Allowed CORS origins (comma-separated). Use * locally; lock down in production.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ----- Database -----
# Local Postgres example. On Railway this is injected automatically as DATABASE_URL.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/nbu_rs

# ----- Anthropic -----
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
# Max output tokens per analysis request.
ANTHROPIC_MAX_TOKENS=2000

# ----- Security -----
# Secret used to sign lightweight session tokens (anonymous submissions).
SESSION_SECRET=change-me-to-a-random-32-byte-string

# ----- Uploads -----
# Max upload size per file, bytes (5 MB default).
MAX_UPLOAD_BYTES=5242880
